{
  "paper": "arXiv:1805.00020",
  "madgraph_executable": "madgraph_work/external/MG5_aMC_v3_7_1/bin/mg5_aMC",
  "import_model": "EWdim6-full",
  "process": "p p > h j j QCD=0 NP<=2, (h > z z NP<=2, z > l+ l-)",
  "add_processes": [],
  "coefficient_names": ["fW", "fWW"],
  "theta_true": [
    [-0.5, -0.5],
    [-0.8, 0.6],
    [0.3, 0.4],
    [0.0, 0.0],
    [0.393, 0.492]
