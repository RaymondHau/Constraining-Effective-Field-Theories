{
  "name": "paper_10m_full_workflow",
  "python": "auto",
  "log_dir": "logs/script_workflow_logs",
  "env": {},
  "stages": [
    {
      "name": "event_generation",
      "script": "scripts/EFT_event_generation.py",
      "enabled": true,
      "config": "paper_10m/event_generation.json"
    },
    {
      "name": "prepare_samples",
      "script": "scripts/EFT_prepare_samples.py",
      "enabled": true,
      "config": "paper_10m/sample_preparation.json"
    },
    {
      "name": "train_estimators",
      "script": "scripts/EFT_train_estimators.py",
      "enabled": true,
      "config": "paper_10m/neural_training.json"
    }
  ]
}




